# <h1>Restaurants#index</h1>
# <p>Find me in app/views/restaurants/index.html.erb</p>

<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Restaurants</h1>
    <%= link_to "Add a restaurant", new_restaurant_path, class: "btn btn-primary" %>
  </div>

  <% if @restaurants.any? %>
    <div class="list-group">
      <% @restaurants.each do |restaurant| %>
        <%= link_to restaurant_path(restaurant), class: "list-group-item list-group-item-action" do %>
          <div class="d-flex w-100 justify-content-between">
            <h5 class="mb-1"><%= restaurant.name %></h5>
            <small class="text-muted"><%= restaurant.category %></small>
          </div>
          <p class="mb-1"><%= restaurant.address %></p>
          <small class="text-muted"><%= restaurant.phone_number %></small>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="mt-3 text-muted">No restaurants yet. Add the first one!</p>
  <% end %>
</div>
