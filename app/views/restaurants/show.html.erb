# <h1>Restaurants#show</h1>
# <p>Find me in app/views/restaurants/show.html.erb</p>

<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0"><%= @restaurant.name %></h1>
    <%= link_to "Back", restaurants_path, class: "btn btn-outline-secondary" %>
  </div>

  <p><strong>Address:</strong> <%= @restaurant.address %></p>
  <p><strong>Phone:</strong> <%= @restaurant.phone_number %></p>
  <p><strong>Category:</strong> <%= @restaurant.category %></p>

  <hr>

  <div class="d-flex justify-content-between align-items-center">
    <h2 class="h4 mb-0">Reviews</h2>
    <%= link_to "Add a review", new_restaurant_review_path(@restaurant), class: "btn btn-sm btn-primary" %>
  </div>

  <div class="mt-3">
    <% if @restaurant.reviews.any? %>
      <% @restaurant.reviews.each do |review| %>
        <div class="border rounded p-3 mb-2">
          <div><strong>Rating:</strong> <%= review.rating %>/5</div>
          <div><%= review.content %></div>
        </div>
      <% end %>
    <% else %>
      <p class="text-muted mt-2">No reviews yet.</p>
    <% end %>
  </div>
</div>
